[gd_scene load_steps=5 format=2]

[ext_resource path="res://prefabs/net/net.gd" type="Script" id=1]
[ext_resource path="res://prefabs/net/part_helper.gd" type="Script" id=2]
[ext_resource path="res://prefabs/net/settings_helper.gd" type="Script" id=3]
[ext_resource path="res://prefabs/net/bot_helper.gd" type="Script" id=4]

[node name="Net" type="Node"]
script = ExtResource( 1 )

[node name="Heartbeat" type="Timer" parent="."]
autostart = true

[node name="RequestSet" type="HTTPRequest" parent="."]
use_threads = true

[node name="PartHelper" type="Node" parent="."]
script = ExtResource( 2 )

[node name="SettingsHelper" type="Node" parent="."]
script = ExtResource( 3 )

[node name="BotHelper" type="Node" parent="."]
script = ExtResource( 4 )

[connection signal="timeout" from="Heartbeat" to="." method="_heartbeat"]
